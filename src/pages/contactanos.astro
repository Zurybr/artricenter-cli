---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Contacto y Citas | Artricenter"
  description="Agenda una valoracion en Artricenter y conoce horarios, ubicacion y el proceso para iniciar tu tratamiento reumatologico."
  currentPage="/contactanos"
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Blog -->
    <section id="blog" class="mb-16">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-blue-600 mb-6">Blog</h2>

        <div class="space-y-4 text-gray-700 leading-relaxed text-lg mb-8">
          <p>
            Publicamos temas de interés sobre reumatología, diagnóstico oportuno y recomendaciones de bienestar para vivir mejor con enfermedades crónicas.
          </p>
        </div>

        <a
          href="https://artricenter.com.mx/blog/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200"
        >
          <span>Visitar nuestro blog</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- Separator -->
    <div class="flex items-center justify-center gap-6 my-16">
      <div class="h-1 w-40 bg-gradient-to-r from-transparent via-blue-500 to-blue-600 rounded-full"></div>
      <div class="flex gap-2">
        <div class="w-3 h-3 bg-blue-600 rounded-full animate-pulse"></div>
        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
      </div>
      <div class="h-1 w-40 bg-gradient-to-l from-transparent via-blue-500 to-blue-600 rounded-full"></div>
    </div>

    <!-- Contact Form -->
    <section id="contactanos" class="py-12">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-blue-600 mb-4">Contáctanos</h2>
          <p class="text-gray-600 text-lg">
            Estamos aquí para ayudarte. Déjanos tus datos y nos comunicaremos contigo lo más pronto posible.
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-8 md:p-12 border border-gray-100">
          <form id="contact-form" class="space-y-8">
            <!-- Email or Phone -->
            <div class="space-y-3">
              <label for="contact-info" class="flex items-center gap-2 text-sm font-semibold text-gray-800">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/>
                </svg>
                <span>Correo electrónico o número de teléfono</span>
              </label>
              <div class="relative">
                <input
                  type="text"
                  id="contact-info"
                  name="contact-info"
                  required
                  placeholder="ejemplo@correo.com o 55-1234-5678"
                  class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-lg bg-gray-50 hover:bg-white"
                />
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none">
                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div class="space-y-3">
              <label for="message" class="flex items-center gap-2 text-sm font-semibold text-gray-800">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
                </svg>
                <span>Mensaje</span>
              </label>
              <div class="relative">
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  placeholder="Escribe tu mensaje aquí. Si tienes alguna duda, no dudes en contactarnos..."
                  class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all duration-200 text-lg bg-gray-50 hover:bg-white resize-none"
                ></textarea>
                <div class="absolute bottom-4 right-4 pointer-events-none">
                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                </div>
              </div>
              <p class="text-sm text-gray-500 italic">
                <svg class="w-4 h-4 inline-block mr-1 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
                Nos comunicaremos contigo lo más pronto posible. Si tienes alguna duda, envíanos un mensaje y con gusto te apoyaremos.
              </p>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
              <button
                type="submit"
                class="w-full inline-flex items-center justify-center gap-3 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-bold px-8 py-5 rounded-xl shadow-xl hover:shadow-2xl transition-all duration-200 transform hover:-translate-y-1 text-lg"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <span>Enviar mensaje por WhatsApp</span>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </button>
            </div>
          </form>

          <!-- Divider -->
          <div class="flex items-center gap-4 my-8">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-gray-400 text-sm font-medium">O contacta directamente</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

          <!-- Contact Info Cards -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Phone Card -->
            <a href="tel:015513464000" class="group flex items-center gap-4 p-5 bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl border-2 border-blue-200 hover:border-blue-400 hover:shadow-lg transition-all duration-200">
              <div class="flex-shrink-0 w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-blue-600 font-semibold uppercase tracking-wide">Teléfono</p>
                <p class="text-gray-900 font-bold text-lg group-hover:text-blue-700 transition-colors">01 (55) 1346-4000</p>
              </div>
            </a>

            <!-- WhatsApp Card -->
            <a href="https://wa.me/525559890607" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 p-5 bg-gradient-to-br from-green-50 to-green-100 rounded-xl border-2 border-green-200 hover:border-green-400 hover:shadow-lg transition-all duration-200">
              <div class="flex-shrink-0 w-12 h-12 bg-green-600 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs text-green-600 font-semibold uppercase tracking-wide">WhatsApp</p>
                <p class="text-gray-900 font-bold text-lg group-hover:text-green-700 transition-colors">55-5989-0607</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <script>
      const form = document.getElementById('contact-form');
      form?.addEventListener('submit', (e) => {
        e.preventDefault();

        const contactInfo = document.getElementById('contact-info').value;
        const message = document.getElementById('message').value;

        // Create WhatsApp message
        const whatsappMessage = encodeURIComponent(
          `¡Hola! Me gustaría contactarlos.\n\nDatos de contacto: ${contactInfo}\n\nMensaje: ${message}`
        );

        // Open WhatsApp with the message
        window.open(`https://wa.me/525559890607?text=${whatsappMessage}`, '_blank');

        // Reset form
        form.reset();
      });
    </script>
  </div>
</Layout>
