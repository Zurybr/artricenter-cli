---
import Layout from '@/layouts/Layout.astro';
---

<Layout
  title="Club Vida y Salud | Artricenter"
  description="Recursos para pacientes con recomendaciones de autocuidado, actividad fisica segura y educacion en salud articular."
  currentPage="/club-vida-y-salud"
>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Club Vida y Salud -->
    <section id="club-vida-y-salud" class="mb-16">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-blue-600 mb-6 text-center">Club Vida y Salud</h2>

        <div class="space-y-4 text-gray-700 leading-relaxed text-lg">
          <p>
            Club Vida y Salud es un programa dirigido a los pacientes de <strong class="text-blue-600">Artricenter</strong> que terminaron la etapa de Tratamiento Médico Integral y, por lo tanto, obtuvieron una mejoría significativa en su enfermedad reumática.
          </p>

          <p>
            El principal objetivo de Club Vida y Salud es asegurar la continuidad de la mejora en la calidad de vida obtenida por nuestros pacientes durante su tratamiento, ya que las enfermedades reumáticas son progresivas y es necesario mantenerlas controladas.
          </p>

          <p>
            Este programa asegura a cada uno de los pacientes de <strong class="text-blue-600">Artricenter</strong> que su enfermedad reumática se mantendrá controlada durante toda su vida.
          </p>
        </div>
      </div>
    </section>

    <!-- Separator -->
    <div class="flex items-center justify-center gap-6 my-16">
      <div class="h-1 w-40 bg-gradient-to-r from-transparent via-blue-500 to-blue-600 rounded-full"></div>
      <div class="flex gap-2">
        <div class="w-3 h-3 bg-blue-600 rounded-full animate-pulse"></div>
        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
      </div>
      <div class="h-1 w-40 bg-gradient-to-l from-transparent via-blue-500 to-blue-600 rounded-full"></div>
    </div>

    <!-- Testimonios Carousel -->
    <section id="testimonios" class="mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-blue-600 mb-12 text-center">Testimonios</h2>

      <div class="relative max-w-4xl mx-auto">
        <!-- Carousel Container -->
        <div id="testimonial-carousel" class="overflow-hidden rounded-2xl">
          <div class="flex transition-transform duration-500 ease-in-out" id="carousel-track">
            <!-- Testimonio 1 -->
            <div class="w-full flex-shrink-0 px-4">
              <div class="relative rounded-2xl shadow-2xl overflow-hidden max-w-md mx-auto">
                <img
                  src="/assets/maria.avif"
                  alt="María del Rosario"
                  class="w-full h-[650px] object-cover object-top"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/60 to-transparent"></div>
                <div class="absolute inset-0 p-6 flex flex-col justify-end">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </div>
                  <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">María del Rosario</h3>
                  <div class="relative mb-3">
                    <svg class="absolute -top-1 -left-1 w-8 h-8 text-white/30" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                    </svg>
                    <p class="text-white/95 text-sm md:text-base leading-relaxed pl-6">
                      Llegué a Artricenter porque el dolor y la inflamación en mis manos ya estaban afectando mi trabajo y mis actividades diarias. Me diagnosticaron artritis y, aunque tenía miedo, desde la primera consulta sentí mucha confianza por la explicación tan clara y el trato tan humano.
                    </p>
                  </div>
                  <p class="text-white/95 text-sm md:text-base leading-relaxed mb-3">
                    Llevo 2 años en tratamiento médico integral y mi mejoría ha sido bastante buena. La inflamación ha disminuido considerablemente, tengo mayor movilidad y, sobre todo, he recuperado calidad de vida. Ahora puedo realizar mis actividades con mucha más seguridad y menos dolor.
                  </p>
                  <div class="flex items-center gap-2 text-white/90">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-sm font-medium">Paciente verificada</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Testimonio 2 -->
            <div class="w-full flex-shrink-0 px-4">
              <div class="relative rounded-2xl shadow-2xl overflow-hidden max-w-md mx-auto">
                <img
                  src="/assets/maria2.avif"
                  alt="María del Rosario"
                  class="w-full h-[650px] object-cover object-top"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/60 to-transparent"></div>
                <div class="absolute inset-0 p-6 flex flex-col justify-end">
                  <div class="flex items-center gap-2 mb-3">
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  </div>
                  <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">María del Rosario</h3>
                  <div class="relative mb-3">
                    <svg class="absolute -top-1 -left-1 w-8 h-8 text-white/30" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                    </svg>
                    <p class="text-white/95 text-sm md:text-base leading-relaxed pl-6">
                      Llegué a Artricenter porque el dolor y la inflamación en mis manos ya estaban afectando mi trabajo y mis actividades diarias. Me diagnosticaron artritis y, aunque tenía miedo, desde la primera consulta sentí mucha confianza por la explicación tan clara y el trato tan humano.
                    </p>
                  </div>
                  <p class="text-white/95 text-sm md:text-base leading-relaxed mb-3">
                    Llevo 2 años en tratamiento médico integral y mi mejoría ha sido bastante buena. La inflamación ha disminuido considerablemente, tengo mayor movilidad y, sobre todo, he recuperado calidad de vida. Ahora puedo realizar mis actividades con mucha más seguridad y menos dolor.
                  </p>
                  <div class="flex items-center gap-2 text-white/90">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-sm font-medium">Paciente verificada</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation Arrows -->
        <button
          id="prev-btn"
          class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-white rounded-full shadow-lg p-3 hover:bg-blue-50 transition-colors z-30 border-2 border-blue-600"
          aria-label="Anterior"
        >
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button
          id="next-btn"
          class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-white rounded-full shadow-lg p-3 hover:bg-blue-50 transition-colors z-30 border-2 border-blue-600"
          aria-label="Siguiente"
        >
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

        <!-- Indicators -->
        <div class="flex justify-center gap-2 mt-6">
          <button id="dot-0" class="w-3 h-3 rounded-full bg-blue-600 transition-all duration-300" aria-label="Testimonio 1"></button>
          <button id="dot-1" class="w-3 h-3 rounded-full bg-gray-300 transition-all duration-300" aria-label="Testimonio 2"></button>
        </div>
      </div>
    </section>

    <script>
      const track = document.getElementById('carousel-track');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      const dots = [
        document.getElementById('dot-0'),
        document.getElementById('dot-1')
      ];
      let currentIndex = 0;
      const totalSlides = 2;

      function updateCarousel() {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.remove('bg-gray-300');
            dot.classList.add('bg-blue-600');
          } else {
            dot.classList.remove('bg-blue-600');
            dot.classList.add('bg-gray-300');
          }
        });
      }

      prevBtn.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
        updateCarousel();
      });

      nextBtn.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % totalSlides;
        updateCarousel();
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          currentIndex = index;
          updateCarousel();
        });
      });

      // Auto-play
      setInterval(() => {
        currentIndex = (currentIndex + 1) % totalSlides;
        updateCarousel();
      }, 5000);
    </script>
  </div>
</Layout>
