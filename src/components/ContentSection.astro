---
interface Props {
  id: string;
  title: string;
  children?: any;
}

const { id, title } = Astro.props;
---

<section id={id} class="max-w-7xl mx-auto px-4 py-12">
  <h2 class="text-3xl font-bold text-gray-900 mb-6">{title}</h2>
  <div class="prose prose-lg max-w-none">
    <slot />
  </div>
</section>
