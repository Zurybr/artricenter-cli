        </a>
      </div>

      <!-- Viaducto -->
      <div class="group bg-white border border-gray-200 rounded-xl p-6 hover:border-orange-300 hover:shadow-lg transition-all duration-300">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 bg-orange-600 rounded-lg flex items-center justify-center">
