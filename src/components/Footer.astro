---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-200 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Header Section -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Nuestras Sucursales</h2>
      <p class="text-gray-600 text-lg">Ubicaciones estratégicas para atenderte cerca de ti</p>
      <div class="flex items-center justify-center gap-6 mt-6">
        <div class="h-1 w-20 bg-gradient-to-r from-transparent via-blue-500 to-blue-600 rounded-full"></div>
        <div class="flex gap-2">
          <div class="w-3 h-3 bg-blue-600 rounded-full animate-pulse"></div>
          <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
        </div>
        <div class="h-1 w-20 bg-gradient-to-l from-transparent via-blue-500 to-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Sucursales Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <!-- La Raza -->
      <div class="group bg-white border border-gray-200 rounded-xl p-6 hover:border-blue-300 hover:shadow-lg transition-all duration-300">
