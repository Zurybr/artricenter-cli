            <p class="text-blue-600 text-sm font-medium">Artricenter La Raza</p>
          </div>
        </div>

        <div class="space-y-3 mb-4">
          <p class="text-gray-700 text-sm leading-relaxed">
            <span class="font-semibold text-gray-900">📍 Calzada Vallejo 233</span><br/>
            Héroes de Nacozári, GAM<br/>
            07780 CDMX
