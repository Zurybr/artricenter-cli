---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white mt-auto relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-64 h-64 bg-green-500/10 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Header Section -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Visítanos</h2>
      <p class="text-gray-300 text-lg">Tres sucursales para atenderte cerca de ti</p>
      <div class="flex items-center justify-center gap-6 mt-6">
        <div class="h-1 w-20 bg-gradient-to-r from-transparent via-blue-500 to-blue-600 rounded-full"></div>
        <div class="flex gap-2">
          <div class="w-3 h-3 bg-blue-500 rounded-full animate-pulse"></div>
          <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
        </div>
        <div class="h-1 w-20 bg-gradient-to-l from-transparent via-blue-500 to-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Sucursales Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <!-- La Raza -->
