          </svg>
          Ver en Google Maps
        </a>
      </div>
    </div>

    <!-- Info Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-8 border-t border-gray-200">
      <!-- Horarios -->
      <div class="text-center md:text-left">
        <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center justify-center md:justify-start gap-2">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Horarios de Atención
        </h3>
        <p class="text-gray-700">
          Martes a sábado<br/>
          <span class="text-xl font-bold text-blue-600">8:00 - 17:00</span> horas
        </p>
      </div>

      <!-- Contacto -->
      <div class="text-center md:text-left">
        <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center justify-center md:justify-start gap-2">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
