---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Contacto -->
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Contacto</h3>
        <ul class="space-y-3 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <div>
              <p class="font-medium">Teléfono</p>
              <p class="text-blue-600 hover:text-blue-700">01 (55) 1346-4000</p>
            </div>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div>
              <p class="font-medium">WhatsApp</p>
              <p class="text-green-600 hover:text-green-700">55-5989-0607</p>
            </div>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
              <p class="font-medium">Horario</p>
              <p>Martes a sábado: 8:00 - 17:00 horas</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Redes Sociales -->
      <div>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Síguenos</h3>
        <div class="flex gap-4">
          <a href="https://www.facebook.com/Artricenter" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700 transition-colors" aria-label="Facebook">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://x.com/Artricenter" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-500 transition-colors" aria-label="Twitter">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/artricenter/" target="_blank" rel="noopener noreferrer" class="text-blue-700 hover:text-blue-800 transition-colors" aria-label="LinkedIn">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Sucursales con Mapas -->
    <div class="mt-8 pt-8 border-t border-gray-200">
      <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Nuestras Sucursales</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- La Raza -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="p-4 bg-gradient-to-r from-blue-500 to-blue-600">
            <h4 class="text-lg font-bold text-white flex items-center gap-2">
              <div class="w-3 h-3 bg-white rounded-full"></div>
              La Raza
            </h4>
          </div>
          <div class="p-4">
            <p class="text-sm text-gray-700 mb-4">
              <strong>Calzada Vallejo 233</strong><br/>
              Héroes de Nacozári, Gustavo A. Madero<br/>
              07780 Ciudad de México, CDMX
            </p>
            <a
              href="https://www.google.com/maps/search/?api=1&query=Calzada+Vallejo+233+H%C3%A9roes+de+Nacoz%C3%A1ri+Gustavo+A+Madero+Ciudad+de+M%C3%A9xico"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 font-medium text-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <!-- Atizapán -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="p-4 bg-gradient-to-r from-green-500 to-green-600">
            <h4 class="text-lg font-bold text-white flex items-center gap-2">
              <div class="w-3 h-3 bg-white rounded-full"></div>
              Atizapán
            </h4>
          </div>
          <div class="p-4">
            <p class="text-sm text-gray-700 mb-4">
              <strong>Boulevard Adolfo López Mateos 65</strong><br/>
              Mz. 1 Lt. 16 Zona 8, El Potrero<br/>
              57975 Ex-Ejido de Atizapán III, Edo. México
            </p>
            <a
              href="https://www.google.com/maps/search/?api=1&query=Boulevard+Adolfo+L%C3%B3pez+Mateos+65+Atizap%C3%A1n+Estado+de+M%C3%A9xico"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-green-600 hover:text-green-700 font-medium text-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>

        <!-- Viaducto -->
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="p-4 bg-gradient-to-r from-orange-500 to-orange-600">
            <h4 class="text-lg font-bold text-white flex items-center gap-2">
              <div class="w-3 h-3 bg-white rounded-full"></div>
              Viaducto
            </h4>
          </div>
          <div class="p-4">
            <p class="text-sm text-gray-700 mb-4">
              <strong>Viaducto Río de la Piedad 130</strong><br/>
              Jamaica, Venustiano Carranza<br/>
              15800 Ciudad de México, CDMX
            </p>
            <a
              href="https://www.google.com/maps/search/?api=1&query=Viaducto+R%C3%ADo+de+la+Piedad+130+Jamaica+Venustiano+Carranza+Ciudad+de+M%C3%A9xico"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-orange-600 hover:text-orange-700 font-medium text-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Ver en Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-gray-200 text-center text-sm text-gray-500">
      <p>&copy; {currentYear} Artricenter. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
