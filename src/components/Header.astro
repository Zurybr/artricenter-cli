---
import Navigation from './Navigation.astro';
import { NavItem } from '@/config/navigation';

interface Props {
  navItems: NavItem[];
  currentPage: string;
}

const { navItems, currentPage } = Astro.props;
---

<!-- Logo grande centrado - NO sticky -->
<div class="bg-gradient-to-r from-blue-50 to-white border-b border-gray-100">
  <div class="flex justify-center py-6">
    <a
      href="/"
      class="flex items-center justify-center"
      aria-label="Ir a la página principal de Artricenter"
    >
      <img
        src="/assets/logo.png"
        alt="Artricenter"
        class="h-40 w-auto"
      />
    </a>
  </div>
</div>

<!-- Navegación centrada - STICKY -->
<header class="bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Mobile Menu Toggle - Left side for easy thumb access -->
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center p-3 rounded-xl text-gray-700 hover:text-blue-600 hover:bg-blue-50 transition-all duration-200 active:scale-95"
        aria-expanded="false"
        data-mobile-toggle
        aria-label="Abrir menú principal"
      >
        <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" data-menu-icon>
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="h-7 w-7 hidden" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" data-close-icon>
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Desktop Navigation - Centered -->
      <div class="hidden lg:flex flex-1 items-center justify-center">
        <Navigation items={navItems} currentPage={currentPage} />
      </div>

      <!-- Mobile Logo - Small version centered -->
      <a href="/" class="lg:hidden flex items-center justify-center" aria-label="Ir a inicio">
        <img src="/assets/logo.png" alt="Artricenter" class="h-12 w-auto" />
      </a>

      <!-- Spacer for balance -->
      <div class="w-12 lg:hidden"></div>
    </div>
  </div>

  <!-- Mobile Navigation Menu - Full screen overlay -->
  <div
    class="lg:hidden fixed inset-0 bg-black/50 z-50 hidden transition-opacity duration-300 opacity-0"
    data-mobile-overlay
    aria-hidden="true"
  >
    <div
      class="absolute right-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl transform transition-transform duration-300 translate-x-full"
      data-mobile-panel
    >
      <!-- Mobile Menu Header -->
      <div class="flex items-center justify-between px-4 py-4 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-white">
        <div class="flex items-center gap-3">
          <img src="/assets/logo.png" alt="Artricenter" class="h-10 w-auto" />
          <span class="text-lg font-bold text-gray-900">Menú</span>
        </div>
        <button
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-lg text-gray-700 hover:text-blue-600 hover:bg-blue-50 transition-all duration-200"
          data-mobile-close
          aria-label="Cerrar menú"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Scrollable Menu Content -->
      <nav class="overflow-y-auto h-[calc(100%-64px)] px-4 py-6 space-y-2" aria-label="Navegación móvil">
        {navItems.map(item => (
          <div class="mobile-menu-item">
            <button
              class:list={[
                "w-full flex items-center justify-between px-4 py-4 text-base font-semibold rounded-xl transition-all duration-200 active:scale-[0.98]",
                { "bg-blue-600 text-white shadow-lg": item.page === currentPage },
                { "bg-gray-50 text-gray-900 hover:bg-gray-100": item.page !== currentPage }
              ]}
              data-menu-trigger={item.page}
              aria-expanded="false"
            >
              <span>{item.label}</span>
              {item.children && item.children.length > 0 && (
                <svg class="h-5 w-5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              )}
            </button>

            {item.children && item.children.length > 0 && (
              <div class="hidden ml-4 mt-2 space-y-2 pl-4 border-l-2 border-blue-200" data-submenu={item.page}>
                {item.children.map(child => {
                  const isExternal = child.page.startsWith('http://') || child.page.startsWith('https://');
                  const fullHref = isExternal ? child.page : child.page + (child.hash || '');
                  const childIsActive = !isExternal && child.page === currentPage;
                  return (
                    <a
                      href={fullHref}
                      class:list={[
                        "block px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 active:scale-[0.98]",
                        { "bg-blue-100 text-blue-700": childIsActive },
                        { "text-gray-700 hover:bg-gray-50 hover:text-blue-600": !childIsActive }
                      ]}
                      target={isExternal ? '_blank' : undefined}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                    >
                      <div class="flex items-center gap-2">
                        <span class="flex-1">{child.label}</span>
                        {isExternal && (
                          <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  // Mobile menu functionality
  const mobileToggle = document.querySelector('[data-mobile-toggle]');
  const mobileClose = document.querySelector('[data-mobile-close]');
  const mobileOverlay = document.querySelector('[data-mobile-overlay]');
  const mobilePanel = document.querySelector('[data-mobile-panel]');
  const menuIcon = document.querySelector('[data-menu-icon]');
  const closeIcon = document.querySelector('[data-close-icon]');
  const menuTriggers = document.querySelectorAll('[data-menu-trigger]');

  function openMenu() {
    mobileOverlay?.classList.remove('hidden');
    mobilePanel?.classList.remove('translate-x-full');
    menuIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    mobileToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';

    // Trigger animation
    setTimeout(() => {
      mobileOverlay?.classList.remove('opacity-0');
    }, 10);
  }

  function closeMenu() {
    mobileOverlay?.classList.add('opacity-0');
    mobilePanel?.classList.add('translate-x-full');
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    mobileToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    setTimeout(() => {
      mobileOverlay?.classList.add('hidden');
    }, 300);
  }

  mobileToggle?.addEventListener('click', openMenu);
  mobileClose?.addEventListener('click', closeMenu);
  mobileOverlay?.addEventListener('click', (e) => {
    if (e.target === mobileOverlay) closeMenu();
  });

  // Submenu toggles
  menuTriggers.forEach(trigger => {
    trigger?.addEventListener('click', () => {
      const page = trigger?.getAttribute('data-menu-trigger');
      const submenu = document.querySelector(`[data-submenu="${page}"]`);
      const icon = trigger?.querySelector('svg');

      if (submenu?.classList.contains('hidden')) {
        submenu?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        trigger?.setAttribute('aria-expanded', 'true');
      } else {
        submenu?.classList.add('hidden');
        icon?.classList.remove('rotate-180');
        trigger?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Close menu on link click
  document.querySelectorAll('[data-mobile-panel] a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
