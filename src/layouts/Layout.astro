---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { navConfig } from '@/config/navigation';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'Artricenter',
  description = 'Clinica enfocada en diagnostico y tratamiento integral de enfermedades reumaticas.',
  currentPage = '/'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:locale" content="es_MX" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Artricenter" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "MedicalClinic",
        "name": "Artricenter",
        "url": "https://artricenter.com/",
        "medicalSpecialty": "Rheumatology",
        "description": "Clinica enfocada en diagnostico y tratamiento integral de enfermedades reumaticas."
      }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 antialiased overflow-x-hidden">
    <Header navItems={navConfig.items} currentPage={currentPage} />

    <main class="min-h-screen">
      <slot />
    </main>

    <Footer />

    <!-- Sticky Buttons -->
    <div class="fixed bottom-0 left-0 right-0 z-50 flex justify-between items-end px-3 pb-3 sm:px-4 sm:pb-4 pointer-events-none gap-2">
      <!-- Left side buttons: Dra. Edith and Home -->
      <div class="flex items-end gap-2 pointer-events-auto">
        <!-- Dra. Edith Button -->
        <a
          href="https://wa.me/525559890607?text=Hola%20Dra.%20Edith,%20tengo%20una%20pregunta%20sobre%20tratamiento%20reumatológico"
          target="_blank"
          rel="noopener noreferrer"
          class="group"
          aria-label="Pregúntale a la Dra. Edith"
        >
          <!-- Mobile compact version -->
          <div class="sm:hidden relative bg-gradient-to-r from-pink-500 to-pink-600 hover:from-pink-600 hover:to-pink-700 text-white p-1.5 rounded-full shadow-2xl hover:shadow-pink-500/50 transition-all duration-300 transform hover:-translate-y-1">
            <div class="relative w-11 h-11 rounded-full overflow-hidden border-2 border-white shadow-lg">
              <img
                src="/assets/dredit.jpg"
                alt="Dra. Edith"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="absolute -inset-1 rounded-full border-2 border-pink-300 animate-ping opacity-75"></div>
          </div>

          <!-- Desktop full version -->
          <div class="hidden sm:block relative bg-gradient-to-r from-pink-500 to-pink-600 hover:from-pink-600 hover:to-pink-700 text-white px-4 py-2.5 rounded-full shadow-2xl hover:shadow-pink-500/50 transition-all duration-300 transform hover:-translate-y-1 hover:scale-105">
            <div class="flex items-center gap-2">
              <div class="relative">
                <div class="w-11 h-11 rounded-full overflow-hidden border-2 border-white shadow-lg">
                  <img
                    src="/assets/dredit.jpg"
                    alt="Dra. Edith"
                    class="w-full h-full object-cover"
                  />
                </div>
                <!-- Pulse animation ring -->
                <div class="absolute -inset-1 rounded-full border-2 border-pink-300 animate-ping opacity-75"></div>
                <!-- Shine effect -->
                <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-transparent via-white/30 to-transparent"></div>
              </div>
              <div class="text-left">
                <p class="text-xs font-semibold leading-tight">Pregúntale a la</p>
                <p class="text-sm font-bold leading-tight">Dra. Edith</p>
              </div>
            </div>
            <!-- Sparkle effects -->
            <div class="absolute -top-1 -right-1 w-2 h-2 bg-yellow-300 rounded-full animate-pulse"></div>
            <div class="absolute top-1/2 -right-1.5 w-1.5 h-1.5 bg-yellow-200 rounded-full animate-pulse delay-100"></div>
            <div class="absolute -bottom-1 right-1/4 w-1.5 h-1.5 bg-yellow-200 rounded-full animate-pulse delay-200"></div>
          </div>
        </a>

        <!-- Home Button -->
        <a
          href="/"
          class="group"
          aria-label="Ir al inicio"
        >
          <!-- Mobile and Desktop version -->
          <div class="relative bg-gradient-to-br from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white w-14 h-14 sm:w-16 sm:h-16 rounded-full shadow-2xl hover:shadow-blue-500/50 flex items-center justify-center transition-all duration-300 transform hover:-translate-y-1 hover:scale-105">
            <svg class="w-6 h-6 sm:w-7 sm:h-7 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
          </div>
        </a>
      </div>

      <!-- WhatsApp Button - Right side -->
      <a
        href="https://wa.me/525559890607?text=%C2%A1Hola!%20Quiero%20agendar%20una%20consulta%20de%20valoraci%C3%B3n%20sin%20costo%20en%20Artricenter."
        target="_blank"
        rel="noopener noreferrer"
        class="group"
        aria-label="Agendar consulta de valoración sin costo"
      >
        <div class="relative">
          <!-- WhatsApp Icon Button -->
          <div class="relative">
            <div class="absolute inset-0 bg-green-500 rounded-full blur-xl opacity-0 group-hover:opacity-75 transition-opacity duration-300 animate-pulse"></div>
            <div class="relative bg-green-500 hover:bg-green-600 w-14 h-14 sm:w-16 sm:h-16 rounded-full shadow-2xl hover:shadow-green-500/50 flex items-center justify-center transition-all duration-300 transform hover:-translate-y-1">
              <!-- WhatsApp Icon -->
              <svg class="w-8 h-8 sm:w-10 sm:h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <!-- Floating badge -->
            <div class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold px-2 py-0.5 rounded-full animate-bounce">
              1
            </div>
          </div>
        </div>
      </a>
    </div>

    <script>
      // Minimal client-side JS for smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    </script>
  </body>
</html>
