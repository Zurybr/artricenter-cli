---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { navConfig } from '@/config/navigation';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title = 'Artricenter',
  description = 'Clinica enfocada en diagnostico y tratamiento integral de enfermedades reumaticas.',
  currentPage = '/'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:locale" content="es_MX" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Artricenter" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "MedicalClinic",
        "name": "Artricenter",
        "url": "https://artricenter.com/",
        "medicalSpecialty": "Rheumatology",
        "description": "Clinica enfocada en diagnostico y tratamiento integral de enfermedades reumaticas."
      }
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <Header navItems={navConfig.items} currentPage={currentPage} />

    <main class="min-h-screen">
      <slot />
    </main>

    <Footer />

    <!-- Sticky Buttons -->
    <div class="fixed bottom-0 left-0 right-0 z-50 flex justify-between items-end px-3 pb-3 sm:px-4 sm:pb-4 pointer-events-none gap-2">
      <!-- Left side buttons: Dra. Edith and Home -->
      <div class="flex items-end gap-2 pointer-events-auto">
        <!-- Dra. Edith Button -->
        <a
          href="https://wa.me/525559890607?text=Hola%20Dra.%20Edith,%20tengo%20una%20pregunta%20sobre%20tratamiento%20reumatológico"
          target="_blank"
          rel="noopener noreferrer"
          class="group"
          aria-label="Pregúntale a la Dra. Edith"
        >
          <!-- Mobile compact version -->
          <div class="sm:hidden relative bg-gradient-to-r from-pink-500 to-pink-600 hover:from-pink-600 hover:to-pink-700 text-white p-1.5 rounded-full shadow-2xl hover:shadow-pink-500/50 transition-all duration-300 transform hover:-translate-y-1">
            <div class="relative w-11 h-11 rounded-full overflow-hidden border-2 border-white shadow-lg">
              <img
                src="/assets/dredit.jpg"
                alt="Dra. Edith"
                class="w-full h-full object-cover"
              />
            </div>
            <div class="absolute -inset-1 rounded-full border-2 border-pink-300 animate-ping opacity-75"></div>
          </div>

          <!-- Desktop full version -->
          <div class="hidden sm:block relative bg-gradient-to-r from-pink-500 to-pink-600 hover:from-pink-600 hover:to-pink-700 text-white px-4 py-2.5 rounded-full shadow-2xl hover:shadow-pink-500/50 transition-all duration-300 transform hover:-translate-y-1 hover:scale-105">
            <div class="flex items-center gap-2">
              <div class="relative">
                <div class="w-11 h-11 rounded-full overflow-hidden border-2 border-white shadow-lg">
                  <img
                    src="/assets/dredit.jpg"
                    alt="Dra. Edith"
                    class="w-full h-full object-cover"
                  />
                </div>
                <!-- Pulse animation ring -->
                <div class="absolute -inset-1 rounded-full border-2 border-pink-300 animate-ping opacity-75"></div>
                <!-- Shine effect -->
                <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-transparent via-white/30 to-transparent"></div>
              </div>
              <div class="text-left">
                <p class="text-xs font-semibold leading-tight">Pregúntale a la</p>
                <p class="text-sm font-bold leading-tight">Dra. Edith</p>
              </div>
            </div>
            <!-- Sparkle effects -->
            <div class="absolute -top-1 -right-1 w-2 h-2 bg-yellow-300 rounded-full animate-pulse"></div>
            <div class="absolute top-1/2 -right-1.5 w-1.5 h-1.5 bg-yellow-200 rounded-full animate-pulse delay-100"></div>
            <div class="absolute -bottom-1 right-1/4 w-1.5 h-1.5 bg-yellow-200 rounded-full animate-pulse delay-200"></div>
          </div>
        </a>

        <!-- Home Button -->
        <a
          href="/"
          class="group"
          aria-label="Ir al inicio"
        >
          <!-- Mobile and Desktop version -->
          <div class="relative bg-gradient-to-br from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white w-11 h-11 sm:w-12 sm:h-12 rounded-full shadow-2xl hover:shadow-blue-500/50 flex items-center justify-center transition-all duration-300 transform hover:-translate-y-1 hover:scale-105">
            <svg class="w-5 h-5 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </div>
        </a>
      </div>

      <!-- WhatsApp Button - Right side -->
      <div class="relative group/dropdown pointer-events-auto">
        <a
          href="https://web.whatsapp.com/send?phone=525559890607&text=%C2%A1Quiero%20agendar%20una%20consulta%20de%20valoraci%C3%B3n%20sin%20costo!"
          target="_blank"
          rel="noopener noreferrer"
          class="block cursor-pointer"
          aria-label="Agendar consulta de valoración sin costo"
        >
          <div class="relative bg-green-500 text-white w-14 h-14 sm:w-16 sm:h-16 rounded-full flex justify-center items-center shadow-lg hover:bg-green-600 transition-all duration-300 ease-out hover:scale-105 active:scale-95">
            <!-- Badge -->
            <div class="absolute -right-1 -top-1 z-10">
              <div class="flex h-6 w-6 items-center justify-center">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span>
                <span class="relative inline-flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white">1</span>
              </div>
            </div>

            <!-- WhatsApp Icon -->
            <svg viewBox="0 0 16 16" class="w-7 h-7 sm:w-8 sm:h-8" fill="currentColor" height="24" width="24" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"></path>
            </svg>

            <!-- Pulse border -->
            <span class="absolute inset-0 rounded-full border-4 border-white/30 scale-100 animate-pulse"></span>
          </div>
        </a>

        <!-- Hover Tooltip -->
        <div class="absolute bottom-full right-0 mb-3 w-72 opacity-0 invisible group-hover/dropdown:opacity-100 group-hover/dropdown:visible transition-all duration-300 z-50">
          <div class="bg-white rounded-2xl shadow-2xl border-2 border-green-500 p-4 text-sm">
            <h3 class="font-bold text-gray-900 mb-2 text-base">Sucursales Ciudad de México, México</h3>
            <div class="space-y-2 text-gray-700 mb-3">
              <p class="font-semibold text-green-600">• La Raza • Atizapán • Viaducto</p>
              <p class="text-xs">Martes a sábado de 08:00 a 18:30 horas</p>
              <p class="font-semibold text-green-600 mt-2">Centro de atención: 55 1346 4000</p>
              <p class="text-xs">Lunes a viernes de 07:00 a 19:00 horas</p>
              <p class="text-xs">Sábados de 07:00 a 18:00 horas</p>
              <p class="font-bold text-green-600 mt-2">55 5989 0607</p>
            </div>
            <div class="border-t pt-2">
              <p class="text-xs text-gray-600 font-semibold">¡Agenda por WhatsApp!</p>
              <p class="text-xs text-gray-500">Aviso de Privacidad</p>
            </div>
            <div class="mt-2 pt-2 border-t">
              <p class="text-xs text-green-600 font-bold">¡Agenda aquí una consulta de valoración sin costo!</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Minimal client-side JS for smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    </script>
  </body>
</html>
